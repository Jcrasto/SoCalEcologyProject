# ─── OpenSky Network (optional — anonymous access is rate-limited) ───────────
# Create credentials at https://opensky-network.org/index.php?option=com_users&view=registration
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ─── AISHub vessel positions ──────────────────────────────────────────────────
# Register free at https://www.aishub.net/api (Marine Cadastre live feed is decommissioned)
AISHUB_USERNAME=

# ─── NASA FIRMS fire detections ──────────────────────────────────────────────
# Register free at https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_KEY=

# ─── HERE Traffic Flow API ────────────────────────────────────────────────────
# Register free tier at https://developer.here.com/
HERE_API_KEY=

# ─── EIA (US Energy Information Administration) ──────────────────────────────
# Register free at https://www.eia.gov/opendata/
EIA_API_KEY=

# ─── FRED (Federal Reserve Economic Data) ────────────────────────────────────
# Register free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Server settings ─────────────────────────────────────────────────────────
PORT=8009
LOG_LEVEL=info
